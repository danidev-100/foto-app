# Server
SERVER_PORT=8080

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/foto_app?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=24h

# Mercado Pago
MP_ACCESS_TOKEN=your-mp-access-token
MP_SANDBOX=true

# Logging
LOG_LEVEL=info

# Shutdown
SHUTDOWN_TIMEOUT=10s
