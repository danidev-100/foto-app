# ── App ──
APP_PORT=80

# ── Database (Neon) ──
# Obtener desde: https://console.neon.tech → tu proyecto → Connection String
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/foto_app?sslmode=require

# ── JWT (generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))") ──
JWT_SECRET=changeme-jwt-secret-min-32-chars

# ── Mercado Pago ──
MP_ACCESS_TOKEN=your-mp-access-token
MP_SANDBOX=true
# Webhook secret para validar firma HMAC (configurar en dashboard MP -> Webhooks)
MP_WEBHOOK_SECRET=

# ── CORS (origen permitido para el frontend) ──
CORS_ORIGIN=http://localhost:80

# ── Bank Transfer Details (opcional, solo si se usa) ──
BANK_NAME=
BANK_CBU=
BANK_ALIAS=
BANK_HOLDER=
BANK_CUIT=
