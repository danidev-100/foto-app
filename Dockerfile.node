# ── Build stage ──
FROM node:20-alpine AS builder

WORKDIR /app

COPY backend/package.json backend/package-lock.json* ./
RUN npm install

COPY backend/ .
RUN npx prisma generate

# ── Runtime stage ──
FROM node:20-alpine

WORKDIR /app
COPY --from=builder /app .

EXPOSE 3001

CMD ["node", "src/server.js"]
