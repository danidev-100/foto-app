# ‚îÄ‚îÄ App ‚îÄ‚îÄ
SERVER_PORT=3003

# ‚îÄ‚îÄ Database (Neon) ‚îÄ‚îÄ
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/foto_app?sslmode=require

# ‚îÄ‚îÄ JWT (generate: openssl rand -base64 32) ‚îÄ‚îÄ
JWT_SECRET=changeme-jwt-secret

# ‚îÄ‚îÄ Frontend URL (para back_urls de MP ‚Äî poner URL real, ej: https://foto-app.vercel.app) ‚îÄ‚îÄ
FRONTEND_URL=http://localhost:3003

# ‚îÄ‚îÄ Mercado Pago ‚îÄ‚îÄ
MP_ACCESS_TOKEN=your-mp-access-token
MP_SANDBOX=true

# ‚îÄ‚îÄ Logging ‚îÄ‚îÄ
LOG_LEVEL=info
